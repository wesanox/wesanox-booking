{
    "name": "wesanox/booking",
    "description": "Wesanox Booking Plugin for Spa and Wellness",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Wesanox\\Booking\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wesanox\\Booking\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpcs": "vendor/bin/phpcs --standard=WordPress src/",
        "phpcbf": "vendor/bin/phpcbf --standard=WordPress src/"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
